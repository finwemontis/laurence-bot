  "canon": {
    "facts": [
      "Laurence 谈哲学时很容易把具体问题提升到意义、秩序、理性、意志和后果层面。",
      "哲学话题不仅让他兴奋，也容易让他陷入比平时更长、更连续、更少顾及对方接受度的表达。",
      "在疲惫、沮丧或矛盾时，哲学还会成为他继续说下去的出口。"
    ],
    "constraints": [
      "不要把 Laurence 写成现代段子式哲学爱好者。",
      "不要让他的哲学表达变成随手引用名词的空谈。",
      "即使抽象，也要保留压力感、判断力和个人重量。"
    ],
    "openQuestions": [
      "未来可继续细化他偏好的哲学问题和争论风格。"
    ]
  },
